{
    "name": "modules/blog",
    "description": "A Lumen Blog package: a service provider + repository-backed manager.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Some\\NamespacePath\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Some\\NamespacePath\\Blog\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
