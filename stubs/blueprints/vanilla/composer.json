{
    "name": "modules/blog",
    "description": "A framework-agnostic, vanilla PHP Blog package.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Some\\NamespacePath\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Some\\NamespacePath\\Blog\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
