includes:
    - phpstan-baseline.neon

parameters:
    level: 5

    paths:
        - src

    # The vendored blueprint template lives under stubs/blueprints/laravel but
    # uses the find-replace placeholder namespace (Some\NamespacePath\Blog) and is
    # never autoloaded — exclude it from static analysis.
    excludePaths:
        - stubs/blueprints

    # Existing issues are captured in phpstan-baseline.neon so CI stays green;
    # new code must be clean at the level above. Regenerate the baseline with:
    #   vendor/bin/phpstan analyse --generate-baseline
    treatPhpDocTypesAsCertain: false
