{
    "name": "laranail/package-scaffolder",
    "description": "Modular (HMVC) application scaffolding for Laravel — generate, manage and migrate self-contained modules.",
    "keywords": [
        "laravel",
        "laranail",
        "package-scaffolder",
        "modules",
        "hmvc",
        "scaffolding",
        "generator",
        "rad"
    ],
    "homepage": "https://opensource.simtabi.com/documentation/laranail/package-scaffolder/",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/package-scaffolder/issues",
        "source": "https://github.com/laranail/package-scaffolder",
        "docs": "https://opensource.simtabi.com/documentation/laranail/package-scaffolder/"
    },
    "require": {
        "php": "^8.4.1 || ^8.5",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-simplexml": "*",
        "laranail/console": "^1.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "friendsofphp/php-cs-fixer": "^v3.52",
        "laravel/framework": "^13.0",
        "laravel/pint": "^1.16",
        "spatie/phpunit-snapshot-assertions": "^5.0",
        "phpstan/phpstan": "^2.0",
        "laranail/package-tools": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\Package\\Scaffolder\\": "src"
        },
        "files": [
            "helpers/helpers.php"
        ],
        "exclude-from-classmap": [
            "stubs/blueprints/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\Package\\Scaffolder\\Tests\\": "tests",
            "Modules\\Recipe\\": "tests/stubs/valid/Recipe"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\Package\\Scaffolder\\Providers\\LaravelModulesServiceProvider"
            ],
            "aliases": {
                "Module": "Simtabi\\Laranail\\Package\\Scaffolder\\Facades\\Module"
            }
        },
        "branch-alias": {
            "dev-master": "13.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "setup": "@composer install",
        "test": "phpunit --no-coverage",
        "test-coverage": "phpunit --coverage-html coverage",
        "test-dirty": "phpunit --no-coverage --order-by=defects --stop-on-defect",
        "update-snapshots": "phpunit --no-coverage -d --update-snapshots",
        "lint": [
            "@pint",
            "@phpstan",
            "@rector"
        ],
        "pint": "vendor/bin/pint --test",
        "pint-fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "rector": "vendor/bin/rector process --dry-run",
        "rector-fix": "vendor/bin/rector process",
        "audit": "@composer audit",
        "composer-audit": "@composer audit --no-interaction",
        "pcf": "vendor/bin/php-cs-fixer fix --verbose"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
