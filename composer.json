{
    "name": "laranail/package-scaffolder",
    "description": "Modular (HMVC) application scaffolding for Laravel — generate, manage and migrate self-contained modules. A laranail fork of nwidart/laravel-modules.",
    "keywords": [
        "modules",
        "laravel",
        "laranail",
        "module",
        "hmvc",
        "scaffolding",
        "rad"
    ],
    "homepage": "https://opensource.simtabi.com/package-scaffolder/",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        },
        {
            "name": "Nicolas Widart",
            "email": "n.widart@gmail.com",
            "homepage": "https://nicolaswidart.com",
            "role": "Original author (nwidart/laravel-modules)"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/package-scaffolder/issues",
        "source": "https://github.com/laranail/package-scaffolder",
        "docs": "https://opensource.simtabi.com/package-scaffolder/docs/"
    },
    "require": {
        "php": "^8.4.1 || ^8.5",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-simplexml": "*",
        "laranail/console": "^1.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "friendsofphp/php-cs-fixer": "^v3.52",
        "laravel/framework": "^13.0",
        "laravel/pint": "^1.16",
        "spatie/phpunit-snapshot-assertions": "^5.0",
        "phpstan/phpstan": "^2.0",
        "laranail/package-tools": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\Package\\Scaffolder\\": "src"
        },
        "files": [
            "helpers/helpers.php"
        ],
        "exclude-from-classmap": [
            "src/Commands/stubs/blueprint/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\Package\\Scaffolder\\Tests\\": "tests",
            "Modules\\Recipe\\": "tests/stubs/valid/Recipe"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\Package\\Scaffolder\\Providers\\LaravelModulesServiceProvider"
            ],
            "aliases": {
                "Module": "Simtabi\\Laranail\\Package\\Scaffolder\\Facades\\Module"
            }
        },
        "branch-alias": {
            "dev-master": "13.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "scripts": {
        "update-snapshots": "phpunit --no-coverage -d --update-snapshots",
        "lint": "pint",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "pcf": "vendor/bin/php-cs-fixer fix --verbose"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
